<!DOCTYPE html>
<html lang="en">
<head>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>⚡</text></svg>">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>FitCom</title>

    <link rel="stylesheet" href="/style.css">

    <!-- SAME FONT EVERYWHERE -->
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body class="dash-body">
<div class="dash-wrapper">

    <!-- SIDEBAR -->
    <aside class="sidebar">
        <div class="sidebar-logo">
            ⚡ <span class="logo-text">FITCOM</span>
        </div>

        <nav class="sidebar-nav">

            <a href="/dashboard" class="nav-item <%= active === 'dashboard' ? 'active' : '' %>">
                🏠 Home
            </a>

            <a href="/friends" class="nav-item <%= active === 'friends' ? 'active' : '' %>">
                👥 Friends
            </a>

            <a href="/activity_log" class="nav-item <%= active === 'activity' ? 'active' : '' %>">
                📋 Activity Log
            </a>

            <a href="/goals" class="nav-item <%= active === 'goals' ? 'active' : '' %>">
                🎯 Goals
            </a>

            <a href="/challenge" class="nav-item <%= active === 'challenge' ? 'active' : '' %>">
                ⚡ Daily Challenge
            </a>

            <a href="/search" class="nav-item <%= active === 'search' ? 'active' : '' %>">
                🔍 Search
            </a>

        </nav>

        <a href="/logout" class="sidebar-logout">🚪 Logout</a>
    </aside>

    <!-- MAIN -->
    <main class="dash-main">

        <!-- HEADER -->
        <div class="dash-header">
            <div class="dash-welcome">🎯 My Goals</div>
            <div class="dash-subtext">Set targets and track your progress</div>
        </div>

        <!-- STATS -->
        <div class="stats-row">
            <div class="stat-card">
                <div class="stat-value"><%= goals.length %></div>
                <div class="stat-label">Total Goals</div>
            </div>
            <div class="stat-card">
                <div class="stat-value">
                    <%= goals.filter(g => g.status === 'in_progress').length %>
                </div>
                <div class="stat-label">In Progress</div>
            </div>
            <div class="stat-card">
                <div class="stat-value">
                    <%= goals.filter(g => g.status === 'completed').length %>
                </div>
                <div class="stat-label">Completed</div>
            </div>
            <div class="stat-card">
                <div class="stat-value">
                    <%= goals.length > 0 ? Math.round((goals.filter(g => g.status === 'completed').length / goals.length) * 100) : 0 %>%
                </div>
                <div class="stat-label">Success Rate</div>
            </div>
        </div>

        <!-- MAIN GRID -->
        <div class="dash-grid">

            <!-- LEFT — ADD GOAL FORM -->
            <div class="dash-col">
                <div class="dash-card">
                    <div class="card-title">➕ Add New Goal</div>
                    <form action="/goals/add" method="POST" style="display:flex; flex-direction:column; gap:14px;">

                        <div class="field-group">
                            <label>Goal Title</label>
                            <input
                                type="text"
                                name="title"
                                placeholder="e.g. Run 5km without stopping"
                                required
                                style="background:#0f1117; border:1px solid #2a2d3a; border-radius:8px; color:#f0f2f8; padding:11px 14px; font-size:0.9rem; font-family:'Inter',sans-serif; outline:none; transition:border-color 0.15s; width:100%;"
                                onfocus="this.style.borderColor='#c8f135'"
                                onblur="this.style.borderColor='#2a2d3a'"
                            />
                        </div>

                        <div class="field-group">
                            <label>Description (optional)</label>
                            <textarea
                                name="description"
                                rows="3"
                                placeholder="Describe your goal in more detail..."
                                style="width:100%; background:#0f1117; border:1px solid #2a2d3a; border-radius:8px; color:#f0f2f8; padding:11px 14px; font-family:'Inter',sans-serif; font-size:0.875rem; resize:none; outline:none; transition:border-color 0.15s;"
                                onfocus="this.style.borderColor='#c8f135'"
                                onblur="this.style.borderColor='#2a2d3a'"
                            ></textarea>
                        </div>

                        <div class="field-group">
                            <label>Target Date (optional)</label>
                            <input
                                type="date"
                                name="target_date"
                                style="background:#0f1117; border:1px solid #2a2d3a; border-radius:8px; color:#f0f2f8; padding:11px 14px; font-size:0.9rem; font-family:'Inter',sans-serif; outline:none; transition:border-color 0.15s; width:100%; color-scheme:dark;"
                                onfocus="this.style.borderColor='#c8f135'"
                                onblur="this.style.borderColor='#2a2d3a'"
                            />
                        </div>

                        <button type="submit" class="btn-accent">Add Goal</button>
                    </form>
                </div>

                <!-- TIP CARD -->
                <div class="dash-card tip-card">
                    <div class="card-title">💡 Goal Setting Tip</div>
                    <div class="tip-text">
                        Make your goals specific and measurable. Instead of "get fit", try "run 5km three times a week for a month".
                    </div>
                </div>
            </div>

            <!-- RIGHT — GOALS LIST -->
            <div class="dash-col">

                <!-- IN PROGRESS -->
                <div class="dash-card">
                    <div class="card-title">🔥 In Progress</div>

                    <% const inProgress = goals.filter(g => g.status === 'in_progress') %>

                    <% if (inProgress.length === 0) { %>
                        <div class="empty-state">No active goals — add one to get started!</div>
                    <% } else { %>
                        <% inProgress.forEach(goal => { %>
                        <div style="background:#0f1117; border:1px solid #2a2d3a; border-radius:10px; padding:16px; margin-bottom:12px;">

                            <!-- GOAL HEADER -->
                            <div style="display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:8px;">
                                <div style="font-weight:600; color:#f0f2f8; font-size:0.95rem;">
                                    <%= goal.title %>
                                </div>
                                <span class="badge badge-active">In Progress</span>
                            </div>

                            <!-- DESCRIPTION -->
                            <% if (goal.description) { %>
                                <div style="color:#5a5f75; font-size:0.875rem; line-height:1.5; margin-bottom:10px;">
                                    <%= goal.description %>
                                </div>
                            <% } %>

                            <!-- TARGET DATE -->
                            <% if (goal.target_date) { %>
                                <div style="font-size:0.78rem; color:#5a5f75; margin-bottom:12px;">
                                    🗓 Target: 
                                    <span style="color:<%= new Date(goal.target_date) < new Date() ? '#ff6b6b' : '#c8f135' %>">
                                        <%= new Date(goal.target_date).toLocaleDateString() %>
                                        <%= new Date(goal.target_date) < new Date() ? '(Overdue)' : '' %>
                                    </span>
                                </div>
                            <% } %>

                            <!-- ACTIONS -->
                            <div style="display:flex; gap:8px;">
                                <form action="/goals/complete" method="POST" style="margin:0;">
                                    <input type="hidden" name="goal_id" value="<%= goal.goal_id %>" />
                                    <button type="submit" class="btn-accent" style="font-size:0.78rem; padding:6px 14px;">
                                        ✅ Mark Complete
                                    </button>
                                </form>
                                <form action="/goals/delete" method="POST" style="margin:0;">
                                    <input type="hidden" name="goal_id" value="<%= goal.goal_id %>" />
                                    <button type="submit"
                                        style="background:none; border:1px solid #2a2d3a; color:#5a5f75; border-radius:8px; padding:6px 14px; font-size:0.78rem; cursor:pointer; font-family:'Inter',sans-serif;"
                                        onclick="return confirm('Delete this goal?')">
                                        🗑 Delete
                                    </button>
                                </form>
                            </div>
                        </div>
                        <% }) %>
                    <% } %>
                </div>

                <!-- COMPLETED -->
                <div class="dash-card">
                    <div class="card-title">✅ Completed</div>

                    <% const completed = goals.filter(g => g.status === 'completed') %>

                    <% if (completed.length === 0) { %>
                        <div class="empty-state">No completed goals yet — keep going!</div>
                    <% } else { %>
                        <% completed.forEach(goal => { %>
                        <div style="background:#0f1117; border:1px solid #2a2d3a; border-radius:10px; padding:16px; margin-bottom:12px; opacity:0.7;">

                            <div style="display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:8px;">
                                <div style="font-weight:600; color:#f0f2f8; font-size:0.95rem; text-decoration:line-through;">
                                    <%= goal.title %>
                                </div>
                                <span class="badge badge-admin">Completed</span>
                            </div>

                            <% if (goal.description) { %>
                                <div style="color:#5a5f75; font-size:0.875rem; line-height:1.5; margin-bottom:10px;">
                                    <%= goal.description %>
                                </div>
                            <% } %>

                            <div style="font-size:0.78rem; color:#5a5f75; margin-bottom:12px;">
                                ✅ Completed on <%= new Date(goal.created_at).toLocaleDateString() %>
                            </div>

                            <form action="/goals/delete" method="POST" style="margin:0;">
                                <input type="hidden" name="goal_id" value="<%= goal.goal_id %>" />
                                <button type="submit"
                                    style="background:none; border:1px solid #2a2d3a; color:#5a5f75; border-radius:8px; padding:6px 14px; font-size:0.78rem; cursor:pointer; font-family:'Inter',sans-serif;"
                                    onclick="return confirm('Delete this goal?')">
                                    🗑 Delete
                                </button>
                            </form>
                        </div>
                        <% }) %>
                    <% } %>
                </div>

            </div>
        </div>
    </main>
</div>
</body>
</html>